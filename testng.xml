<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- data-provider-thread-count caps concurrent scenario threads spawned by @DataProvider(parallel=true).
     Must not exceed SE_NODE_MAX_SESSIONS on the Grid node (currently 3).
     parallel="methods" is not needed here — there is only one @Test method (scenarios()). -->
<suite name="Suite" parallel="none" data-provider-thread-count="3">
    <test name="Tests">
        <classes>
            <class name="com.automation.runners.TestRunner"/>
        </classes>
    </test>
</suite>